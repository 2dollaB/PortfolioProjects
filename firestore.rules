rules_version = '2';

// BeatSync Firestore security rules — v1 (app-only).
//
// Scope: locks down the read/write paths used by the Flutter app in Stage 2
// (auth + studios + cloud sessions + workouts). CEO access and Cloud-Function-
// mediated writes (invites, suspend, impersonate, audit_log) are added in
// Stage 6 / Phase D via custom claims — see TODOs below.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // CEO admin panel: a user carrying the `ceo` custom claim gets cross-studio
    // READ access (overview/monitoring). Writes (suspend/ban/impersonate) stay
    // out of rules — they go through Cloud Functions with the Admin SDK.
    function isCeo() {
      return isSignedIn() && request.auth.token.role == 'ceo';
    }

    function studioData(studioId) {
      return get(/databases/$(database)/documents/studios/$(studioId)).data;
    }

    function isStudioMember(studioId) {
      return isSignedIn()
        && request.auth.uid in studioData(studioId).memberUids;
    }

    // An athlete may add ONLY themselves to a studio's memberUids (join flow).
    // Everything else on the studio doc stays owner-only.
    // TODO(Phase D): move joins to the inviteAthleteToStudio Cloud Function and
    // drop this self-join allowance.
    function isSelfJoin() {
      let incoming = request.resource.data;
      let current = resource.data;
      return incoming.diff(current).affectedKeys().hasOnly(['memberUids'])
        && incoming.memberUids.hasAll(current.memberUids)
        && incoming.memberUids.size() == current.memberUids.size() + 1
        && (request.auth.uid in incoming.memberUids)
        && !(request.auth.uid in current.memberUids);
    }

    // The mirror of isSelfJoin: an athlete may remove ONLY themselves from a
    // studio's memberUids (leave flow). incoming must be a subset of current
    // (no additions), exactly one uid shorter, and the dropped uid is the
    // caller — so a member can't remove anyone else.
    function isSelfLeave() {
      let incoming = request.resource.data;
      let current = resource.data;
      return incoming.diff(current).affectedKeys().hasOnly(['memberUids'])
        && current.memberUids.hasAll(incoming.memberUids)
        && incoming.memberUids.size() == current.memberUids.size() - 1
        && (request.auth.uid in current.memberUids)
        && !(request.auth.uid in incoming.memberUids);
    }

    // The requester owns the studio this user's profile says they belong to.
    // Members set their own studioId at join time, so this only exposes a
    // profile to the trainer the user actually joined.
    function isOwnerOfUsersStudio() {
      return isSignedIn()
        && 'studioId' in resource.data
        && resource.data.studioId is string
        && studioData(resource.data.studioId).ownerUid == request.auth.uid;
    }

    // ── users/{uid} ──────────────────────────────────────────
    // A user reads/writes their own profile doc; the owner of the studio they
    // joined may read it (trainer member list).
    match /users/{uid} {
      allow read: if isUser(uid) || isOwnerOfUsersStudio() || isCeo();
      allow write: if isUser(uid);
    }

    // ── studios/{studioId} ───────────────────────────────────
    match /studios/{studioId} {
      allow read: if isStudioMember(studioId)
        || (isSignedIn() && resource.data.ownerUid == request.auth.uid)
        || isCeo();
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn()
        && (resource.data.ownerUid == request.auth.uid
            || isSelfJoin()
            || isSelfLeave());
      allow delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      // TODO(Phase D): CEO suspend/restore via suspendStudio Cloud Function only.
    }

    // ── invite_codes/{code} ──────────────────────────────────
    // Code → studioId lookup so an athlete can resolve a studio they don't yet
    // belong to (the studios doc itself stays members-only). Exposes only the
    // mapping, no member data. Created/removed by the owning trainer.
    match /invite_codes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && get(/databases/$(database)/documents/studios/$(request.resource.data.studioId))
            .data.ownerUid == request.auth.uid;
      allow delete: if isSignedIn()
        && get(/databases/$(database)/documents/studios/$(resource.data.studioId))
            .data.ownerUid == request.auth.uid;
    }

    // An athlete may feed the live HR board only for themselves, only while
    // the session is live, only if they belong to the session's studio, and
    // only if the trainer hasn't kicked them.
    function canWriteHr(sessionId, uid) {
      let session = get(/databases/$(database)/documents/sessions/$(sessionId)).data;
      return isUser(uid)
        && session.status == 'live'
        && request.auth.uid in studioData(session.studioId).memberUids
        && !(uid in session.get('kickedUids', []));
    }

    // ── sessions/{sessionId} ─────────────────────────────────
    // Only the studio owner hosts sessions; members read them.
    match /sessions/{sessionId} {
      allow read: if isStudioMember(resource.data.studioId) || isCeo();
      allow create: if isSignedIn()
        && request.resource.data.trainerUid == request.auth.uid
        && studioData(request.resource.data.studioId).ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.trainerUid == request.auth.uid;

      // Live HR feed — one subdoc per athlete, written ~1/sec during a session.
      // Delete stays self-only so a kicked athlete can drop their own tile even
      // though canWriteHr now blocks them from posting new readings.
      match /hr/{uid} {
        allow read: if isSignedIn()
          && isStudioMember(get(/databases/$(database)/documents/sessions/$(sessionId)).data.studioId);
        allow create, update: if canWriteHr(sessionId, uid);
        allow delete: if isUser(uid);
      }
    }

    // The requester owns the studio that this workout's owner belongs to
    // (same self-assert membership as isOwnerOfUsersStudio; costs 2 gets).
    function isTrainerOfWorkoutOwner() {
      let owner = get(/databases/$(database)/documents/users/$(resource.data.userId)).data;
      return isSignedIn()
        && 'studioId' in owner
        && owner.studioId is string
        && studioData(owner.studioId).ownerUid == request.auth.uid;
    }

    // The requester hosted the cloud session this workout is linked to.
    // Lets the session-detail screen run `workouts where sessionId == X`
    // across all athletes — provable for list queries because the equality
    // filter pins sessionId, making the get() path constant.
    function isHostOfWorkoutSession() {
      return isSignedIn()
        && 'sessionId' in resource.data
        && resource.data.sessionId is string
        && get(/databases/$(database)/documents/sessions/$(resource.data.sessionId))
            .data.trainerUid == request.auth.uid;
    }

    // ── workouts/{workoutId} ─────────────────────────────────
    // Owned by a single user; that user reads/writes. The trainer of the
    // studio the owner joined may also read (member detail / analytics), as
    // may the host of the session a workout was recorded in (session detail).
    match /workouts/{workoutId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid
            || isTrainerOfWorkoutOwner()
            || isHostOfWorkoutSession()
            || isCeo());
      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      // TODO(Phase D): move trainer read to custom claims; add CEO read.
    }

    // ── trainer_notes/{trainerUid}/members/{memberUid} ───────
    // A trainer's private notes about a member. Trainer-only, both ways —
    // the member never sees them.
    match /trainer_notes/{trainerUid}/members/{memberUid} {
      allow read, write: if isUser(trainerUid);
    }

    // ── audit_log/{entryId} ──────────────────────────────────
    // Cloud Functions only (Admin SDK bypasses these rules). No client access.
    match /audit_log/{entryId} {
      allow read, write: if false;
    }
  }
}
